{{define "title"}}Movie #{{.Movie.ID}}{{end}}

{{define "main"}}
{{with .Movie}}
<div class='snippet'>

  <div class='metadata'>
    <strong>{{.Title}}</strong>
    <span>#{{.ID}}</span>
  </div>

  <div class='poster'>
    <p>Poster: {{.PosterImage}}</p>
  </div>

  <pre><code>{{.Description}}</code></pre>

  <div class='metadata'>
    <time>Release: {{.ReleaseDate}}</time>
  </div>

</div>
{{end}}
{{end}}
